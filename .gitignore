# Python / uv
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
.python-version

# Build / packaging
build/
dist/
*.egg-info/

# Test and type-check caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Editors / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Claude Code worktrees created during development (never a release artifact)
.claude/worktrees/

# agentmaster-retro's run-transcript corpus: prose scratch space, never tracked
.transcripts/

# SQLite journal/WAL sidecars are always transient, unlike the .sqlite3
# database file itself, so they're safe to blanket-ignore without risking a
# fixture database intentionally committed for tests.
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm

# Installer-created backups of files it overwrote
agentmaster-backup-*/

# agentmaster session artifacts (ledgers, telemetry, evidence, phase marker)
# (.agentmaster/* not .agentmaster/ so a directory-parent exclude doesn't
# block the SPEC.md negation below from re-including that one file)
.agentmaster/*
# v2 spec is tracked; rest of the directory remains session workspace
!.agentmaster/SPEC.md
